# WalletConnect project ID (get one at https://cloud.walletconnect.com)
# Optional — WalletConnect connector is disabled without this
VITE_WC_PROJECT_ID=

# ZK Email proving key — IPFS CID (preferred) or direct URL
# After pinning the zkey to IPFS, set the CID here.
# The browser caches it in IndexedDB after first download.
# To pin: npx web3.storage upload circuits/keys/anthropic-email-light.zkey
VITE_ZKEY_CID=

# Direct URL override (optional — skips IPFS, useful for local dev)
# For local dev with the file on disk, run: scripts/setup-frontend-zk.sh
VITE_ZKEY_URL=
